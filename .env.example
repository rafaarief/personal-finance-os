# Postgres connection (docker compose up -d starts a local instance matching these creds)
DATABASE_URL=postgresql://pfos:pfos@localhost:5432/pfos

# Claude (Anthropic) — used for bank statement extraction/categorization.
# Required: statement import has no deterministic fallback, it will fail clearly without a key.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# Cosmetic only, shown in the UI ("Welcome back, {OWNER_NAME}")
OWNER_NAME=Rafa
